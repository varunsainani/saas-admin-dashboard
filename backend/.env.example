# PostgreSQL connection string (Neon, Back4app, local, etc.)
DATABASE_URL="postgresql://localhost:5432/vantage?schema=public"

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=15m

PORT=4000
# Restrict to your deployed frontend origin in production
CORS_ORIGIN=*
# Seed demo data on `npm run seed`
SEED_DEMO=true

# Email (Resend). Without these, verification links are logged instead of sent.
RESEND_API_KEY=
# Use a verified-domain sender in production; the test sender below only
# delivers to your own Resend account email.
EMAIL_FROM=Vantage <onboarding@resend.dev>
# Public frontend URL, used to build the verification link
APP_URL=http://localhost:3000
